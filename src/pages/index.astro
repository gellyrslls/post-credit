---
// src/pages/index.astro — Home page (route: /)
// Sections: Hero, Latest Posts (3 cards), About blurb

import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

// NOTE (Astro vs Next.js): getCollection() is Astro's equivalent of reading
// from a CMS or calling a data-fetching function in getStaticProps. It reads
// all .md files from src/content/blog/ and validates them against the schema.
const allPosts = await getCollection('blog');

// Sort by date descending, take the 3 most recent for the homepage
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Estimate read time: ~200 words per minute
function estimateReadTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Home"
  description="A reflective digital journal for a CS student navigating the shift from education to the professional AI era."
>

  <!-- ═══════════════════════════════════════════════
       SECTION 1 — HERO
       ═══════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16 sm:pt-28 sm:pb-20">
    <div class="max-w-2xl">

      <!-- H1 — one per page, large and prominent -->
      <h1 class="font-heading text-5xl sm:text-6xl font-bold text-pc-text dark:text-pc-dark-text leading-tight tracking-tight mb-6">
        Post-Credit
      </h1>

      <!-- Subheading paragraph -->
      <p class="font-body text-xl text-pc-muted dark:text-pc-dark-muted leading-relaxed mb-10 max-w-xl">
        A reflective digital journal for a CS student navigating the shift from education to the professional AI era.
      </p>

      <!-- CTA button — links to /blog -->
      <a
        href={`${base}/blog`}
        class="inline-block bg-pc-accent text-pc-accent-text font-body font-medium text-base px-7 py-3 rounded-md hover:opacity-90 active:scale-95 transition-all duration-150"
      >
        Read the Journal
      </a>

    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <hr class="border-pc-border dark:border-gray-800" />
  </div>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 — LATEST POSTS
       ═══════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-6 py-16 sm:py-20">

    <div class="mb-10">
      <h2 class="font-heading text-3xl font-semibold text-pc-text dark:text-pc-dark-text mb-3">
        Latest Updates
      </h2>
      <p class="font-body text-pc-muted dark:text-pc-dark-muted text-base">
        Exploring the intersection of CS education and the AI-driven job market.
      </p>
    </div>

    <!-- 3-column grid on desktop, 1 column on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latestPosts.map((post) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          author={post.data.author}
          description={post.data.description}
          slug={post.id}
          readTime={estimateReadTime(post.body)}
        />
      ))}
    </div>

  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <hr class="border-pc-border dark:border-gray-800" />
  </div>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 — ABOUT BLURB
       ═══════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-6 py-16 sm:py-20">
    <div class="max-w-2xl">

      <h2 class="font-heading text-3xl font-semibold text-pc-text dark:text-pc-dark-text mb-5">
        The Class of 2026: Navigating the AI Era
      </h2>

      <p class="font-body text-base leading-relaxed text-pc-text dark:text-pc-dark-text">
        This blog covers what school does not — the gap between finishing a CS degree and knowing what to actually do next.
        The posts draw from what I am currently navigating rather than from research, which means the writing is honest by necessity.
        Topics include the job market, the AI era's effect on CS education, and the personal cost of prioritizing career
        preparation over everything else during university.
      </p>

    </div>
  </section>

</BaseLayout>
