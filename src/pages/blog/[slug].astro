---
// src/pages/blog/[slug].astro — Individual post page (route: /blog/[slug])
//
// NOTE (Astro vs Next.js): This is Astro's equivalent of Next.js pages/blog/[slug].tsx
// with getStaticPaths. getStaticPaths() tells Astro which slugs exist at build time
// so it can pre-render one HTML file per post. No server needed — 100% static.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// getStaticPaths — runs at build time, returns one path object per blog post.
// params.slug must match the filename (without .md) in src/content/blog/
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

// render() compiles the markdown to HTML — equivalent to MDX rendering in Next.js
// NOTE: In Astro v5+, render() is imported from 'astro:content' directly
const { Content } = await render(post);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Format date for display
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate read time from raw markdown body text
const wordCount = post.body.trim().split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-post mx-auto px-6 pt-12 pb-24">

    <!-- Back to Blog link — top of post -->
    <a
      href={`${base}/blog`}
      class="inline-flex items-center gap-1.5 text-sm font-body text-pc-muted dark:text-pc-dark-muted hover:text-pc-accent dark:hover:text-green-400 transition-colors mb-10 group"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Back to Blog
    </a>

    <!-- Post header -->
    <header class="mb-10">

      <!-- H1 — post title, one per page -->
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-pc-text dark:text-pc-dark-text leading-snug mb-5">
        {post.data.title}
      </h1>

      <!-- Meta line: date · author · read time -->
      <p class="font-body text-sm text-pc-muted dark:text-pc-dark-muted flex flex-wrap items-center gap-x-2 gap-y-1">
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          {formattedDate}
        </time>
        <span aria-hidden="true">·</span>
        <span>{post.data.author}</span>
        <span aria-hidden="true">·</span>
        <span>{readTime} min read</span>
      </p>

    </header>

    <!-- Divider between header and body -->
    <hr class="border-pc-border dark:border-gray-800 mb-10" />

    <!-- Rendered markdown body — prose-post class applies the typography styles from global.css -->
    <div class="prose-post font-body text-base leading-relaxed">
      <Content />
    </div>

    <!-- Back to Blog link — bottom of post too -->
    <div class="mt-16 pt-8 border-t border-pc-border dark:border-gray-800">
      <a
        href={`${base}/blog`}
        class="inline-flex items-center gap-1.5 text-sm font-body text-pc-muted dark:text-pc-dark-muted hover:text-pc-accent dark:hover:text-green-400 transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to Blog
      </a>
    </div>

  </article>
</BaseLayout>
