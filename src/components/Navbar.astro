---
// Navbar.astro — sticky top navigation bar used in BaseLayout on every page.
// NOTE (Astro vs Next.js): The frontmatter block (between --- fences) runs on the server
// at build time — think of it like getStaticProps but inline. Client-side interactivity
// requires a <script> tag or a framework component with client:* directives.

// Get the current URL path to highlight the active nav link
const currentPath = Astro.url.pathname;

// Base path helper — with base: '/post-credit' in astro.config.ts, all routes are
// prefixed. import.meta.env.BASE_URL resolves to '/post-credit/' automatically.
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // strip trailing slash

// Helper to check whether a given href matches the current page
// (exact for /, prefix-match for /blog, /about)
function isActive(href: string): boolean {
  const fullHref = base + href;
  if (href === '/') return currentPath === fullHref || currentPath === fullHref + '/';
  return currentPath.startsWith(fullHref);
}

const navLinks: { href: string; label: string }[] = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
];
---

<!-- Sticky navbar: logo left, nav links right, dark mode toggle rightmost -->
<header class="sticky top-0 z-50 bg-pc-bg/95 dark:bg-pc-dark-bg/95 backdrop-blur-sm border-b border-pc-border dark:border-gray-800 transition-colors">
  <nav
    class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo — links to homepage -->
    <a
      href={`${base}/`}
  class="flex items-center gap-0 shrink-0 group"
  aria-label="Post-Credit home"
>
  <img
    src={`${base}/post-credit-icon.png`}
    alt=""
    width="56"
    height="52"
    class="h-12 w-auto -mr-2 group-hover:opacity-80 transition-opacity"
    loading="eager"
  />
  <span class="font-heading text-2xl font-extrabold leading-none text-pc-text dark:text-pc-dark-text group-hover:text-pc-accent dark:group-hover:text-green-400 transition-colors">
  Post-<br />Credit
</span>
</a>

    <!-- Desktop nav links — hidden on very small screens, flex on sm+ -->
    <ul class="hidden sm:flex items-center gap-6 list-none m-0 p-0" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={`${base}${href}`}
            class:list={[
              'font-body text-sm font-medium transition-colors duration-150',
              isActive(href)
                ? 'text-pc-accent dark:text-green-400 border-b-2 border-pc-accent dark:border-green-400 pb-0.5'
                : 'text-pc-text dark:text-pc-dark-text hover:text-pc-accent dark:hover:text-green-400',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: dark mode toggle + mobile menu area -->
    <div class="flex items-center gap-3">
      <!-- Dark mode toggle button -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="p-2 rounded-md text-pc-muted dark:text-pc-dark-muted hover:text-pc-accent dark:hover:text-green-400 hover:bg-pc-border/50 dark:hover:bg-gray-800 transition-colors"
      >
        <!-- Sun icon (shown in dark mode to switch to light) -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden dark:block"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon icon (shown in light mode to switch to dark) -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="block dark:hidden"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile hamburger — visible on small screens only -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="sm:hidden p-2 rounded-md text-pc-muted hover:text-pc-accent transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu — hidden by default, toggled via JS below -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden border-t border-pc-border dark:border-gray-800"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col px-6 py-4 gap-4 list-none m-0 p-0 px-6 py-4" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={`${base}${href}`}
            class:list={[
              'font-body text-base font-medium transition-colors',
              isActive(href)
                ? 'text-pc-accent dark:text-green-400'
                : 'text-pc-text dark:text-pc-dark-text hover:text-pc-accent dark:hover:text-green-400',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Dark mode toggle logic — runs in the browser
  // NOTE (Astro vs Next.js): scripts in .astro files are bundled and run client-side.
  // No React state here — we directly manipulate the document.

  if (localStorage.getItem('theme') === 'dark') {
  document.documentElement.classList.add('dark');
}

  const toggleBtn = document.getElementById('theme-toggle');
  toggleBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    mobileMenuToggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
